{
  "name": "rugby-tyre-whatsapp-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:dashboard": "vite --config dashboard.vite.config.mjs --configLoader native",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:dashboard\"",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsc -p tsconfig.server.json",
    "build:dashboard": "vite build --config dashboard.vite.config.mjs --configLoader native",
    "start": "node dist/server/index.js",
    "test": "vitest run --environment node --globals",
    "test:watch": "vitest --environment node --globals",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "twilio": "^5.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
