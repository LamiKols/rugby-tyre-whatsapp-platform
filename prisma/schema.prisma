generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(cuid())
  name                   String
  email                  String         @unique
  password_hash          String?
  role                   String         @default("owner")
  active                 Boolean        @default(true)
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  assigned_conversations Conversation[] @relation("AssignedConversations")
  assigned_jobs          Job[]          @relation("AssignedJobs")

  @@map("users")
}

model Customer {
  id            String                @id @default(cuid())
  phone         String                @unique
  whatsapp_id   String?
  name          String?
  email         String?
  notes         String?
  first_seen_at DateTime              @default(now())
  last_seen_at  DateTime              @default(now())
  created_at    DateTime              @default(now())
  updated_at    DateTime              @updatedAt
  conversations Conversation[]
  messages      ConversationMessage[]
  jobs          Job[]

  @@map("customers")
}

model Conversation {
  id               String                @id @default(cuid())
  customer_id      String
  channel          String                @default("whatsapp")
  status           String                @default("active")
  current_intent   String?
  current_state    String                @default("menu")
  failed_attempts  Int                   @default(0)
  state_data       Json?
  handoff_required Boolean               @default(false)
  handoff_reason   String?
  assigned_user_id String?
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  customer         Customer              @relation(fields: [customer_id], references: [id])
  assigned_user    User?                 @relation("AssignedConversations", fields: [assigned_user_id], references: [id])
  messages         ConversationMessage[]
  jobs             Job[]

  @@index([customer_id])
  @@index([handoff_required])
  @@map("conversations")
}

model ConversationMessage {
  id                  String       @id @default(cuid())
  conversation_id     String
  customer_id         String
  direction           String
  provider            String       @default("twilio")
  provider_message_id String?
  body                String?
  message_type        String       @default("text")
  media_url           String?
  location_lat        Decimal?     @db.Decimal(10, 7)
  location_lng        Decimal?     @db.Decimal(10, 7)
  raw_payload         Json?
  created_at          DateTime     @default(now())
  conversation        Conversation @relation(fields: [conversation_id], references: [id])
  customer            Customer     @relation(fields: [customer_id], references: [id])

  @@index([conversation_id, created_at])
  @@map("conversation_messages")
}

model TyreCatalogue {
  id                       String   @id @default(cuid())
  size                     String
  width                    Int
  profile                  Int
  rim                      Int
  brand                    String
  category                 String
  price                    Decimal  @db.Decimal(10, 2)
  fitted_price             Decimal  @db.Decimal(10, 2)
  availability_status      String   @default("available")
  quantity_available       Int?
  is_placeholder_seed_data Boolean  @default(true)
  notes                    String?
  active                   Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@index([size])
  @@map("tyre_catalogue")
}

model AuditLog {
  id          String   @id @default(cuid())
  actor_type  String
  actor_id    String?
  action      String
  entity_type String
  entity_id   String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

model Job {
  id                   String    @id @default(cuid())
  job_reference        String    @unique
  customer_id          String
  conversation_id      String?
  assigned_user_id     String?
  vehicle_registration String?
  job_type             String
  source               String
  status               String    @default("new_request")
  service_required     String?
  scheduled_start      DateTime?
  scheduled_end        DateTime?
  completed_at         DateTime?
  issue_description    String?
  address_text         String?
  location_lat         Decimal?  @db.Decimal(10, 7)
  location_lng         Decimal?  @db.Decimal(10, 7)
  location_source      String?
  preferred_date       DateTime?
  preferred_time_text  String?
  urgency              String    @default("unknown")
  tyre_size            String?
  tyre_description     String?
  tyre_brand           String?
  stock_order_status   String    @default("unknown")
  quantity             Int       @default(1)
  fitter_name          String?
  price                Decimal?  @db.Decimal(10, 2)
  price_estimate       Decimal?  @db.Decimal(10, 2)
  cost                 Decimal?  @db.Decimal(10, 2)
  payment_method       String?   @default("not_paid")
  payment_status       String?   @default("pending")
  notes                String?
  internal_notes       String?
  customer_notes       String?
  cancellation_reason  String?
  reschedule_requested_text String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  customer             Customer  @relation(fields: [customer_id], references: [id])
  conversation         Conversation? @relation(fields: [conversation_id], references: [id])
  assigned_user        User?     @relation("AssignedJobs", fields: [assigned_user_id], references: [id])
  converted_quotes     Quote[]

  @@index([customer_id])
  @@index([conversation_id])
  @@index([assigned_user_id])
  @@index([status])
  @@index([source])
  @@index([urgency])
  @@index([stock_order_status])
  @@map("jobs")
}

model Quote {
  id                   String    @id @default(cuid())
  quote_reference      String    @unique
  customer_name        String?
  phone                String?
  vehicle_registration String?
  tyre_size            String?
  tyre_description     String
  supplier_checked     String?
  supplier_price       Decimal?  @db.Decimal(10, 2)
  quoted_price         Decimal?  @db.Decimal(10, 2)
  status               String    @default("draft")
  notes                String?
  converted_job_id     String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  converted_job        Job?      @relation(fields: [converted_job_id], references: [id])

  @@index([status])
  @@index([phone])
  @@index([converted_job_id])
  @@map("quotes")
}
