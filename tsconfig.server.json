{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["core/**/*.ts", "modules/**/*.ts", "server/**/*.ts", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist", "dashboard", "tests"]
}

